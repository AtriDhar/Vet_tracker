# ── Required in production ───────────────────────────────────────────────────
# Session-signing secret. Generate one with:  openssl rand -base64 32
# The app refuses to start in production without it.
JWT_SECRET=

# ── Database (Turso — free tier) ─────────────────────────────────────────────
# Leave BOTH empty for local development: the app falls back to an embedded
# SQLite file at ./data/vettracker.db (auto-created, auto-migrated, auto-seeded).
#
# For production, create a free database at https://turso.tech and set:
#   TURSO_DATABASE_URL=libsql://<db-name>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<token from `turso db tokens create <db-name>`>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Demo data ────────────────────────────────────────────────────────────────
# On an empty database the app seeds demo accounts (demo@vettracker.app /
# vet@vettracker.app), 3 pets, 14 days of logs and live alerts. Set to "false"
# to skip the demo layer (the vet directory is still seeded — the app needs it).
SEED_DEMO=true
